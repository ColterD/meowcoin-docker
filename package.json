{
    "name": "meowcoin-dashboard",
    "version": "1.0.0",
    "description": "Meowcoin Node Dashboard",
    "private": true,
    "workspaces": [
      "frontend",
      "backend",
      "shared"
    ],
    "scripts": {
      "prepare": "npm run build:shared",
      "build:shared": "cd shared && npm run build",
      "dev:frontend": "cd frontend && npm run dev",
      "dev:backend": "cd backend && npm run dev",
      "dev": "npm run build:shared && concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
      "build:frontend": "cd frontend && npm run build",
      "build:backend": "cd backend && npm run build",
      "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
      "start": "cd backend && npm start",
      "lint": "eslint \"**/*.{ts,tsx}\" --ignore-path .gitignore",
      "test": "npm run test:backend && npm run test:frontend",
      "test:frontend": "cd frontend && npm test",
      "test:backend": "cd backend && npm test",
      "clean": "rimraf node_modules && rimraf */node_modules && rimraf */dist",
      "clean:all": "npm run clean && rimraf package-lock.json && rimraf */package-lock.json",
      "check-types": "tsc --noEmit -p shared/tsconfig.json && cd frontend && tsc --noEmit && cd ../backend && tsc --noEmit",
      "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
    },
    "devDependencies": {
      "concurrently": "^8.2.2",
      "cross-env": "^7.0.3",
      "eslint": "^8.56.0",
      "prettier": "^3.0.0",
      "rimraf": "^5.0.5",
      "typescript": "^5.2.2"
    },
    "engines": {
      "node": ">=16",
      "npm": ">=8"
    }
}