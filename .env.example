# Meowcoin Node Configuration

# Node Operation Mode
# Options: full, pruned, light
# Default: full
MEOWCOIN_MODE=full

# Network ports
RPC_PORT=9766
P2P_PORT=8788
WEB_PORT=8080

# Performance tuning
# Set to specific MB value or "auto" to determine based on system (default: 2048 MB if auto fails)
SYSTEM_MEMORY=auto

# Connection limits
# Set to specific number or "auto" to determine based on system (default: 100 if auto fails)
MAX_CONNECTIONS=auto

# Features
# Enable transaction indexing (1=enabled, 0=disabled)
ENABLE_TXINDEX=1

# Updates
# Options: none, security, minor, all
AUTO_UPDATE=security

# Backup configuration
# Enable automatic wallet backups (true/false)
BACKUP_ENABLED=true

# Backup interval
# Options: hourly, daily, weekly
BACKUP_INTERVAL=daily

# Backup directory
# Default location for backups
BACKUP_DIRECTORY=/data/backups

# Logging level
# Options: error, warning, info, debug
LOG_LEVEL=info

# Additional Meowcoin options (passed directly to meowcoind)
MEOWCOIN_OPTIONS="-maxmempool=500 -disablewallet=0"