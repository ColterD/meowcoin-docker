# Node Configuration
server=1
listen=1
txindex=1

# Network Settings
rpcbind=${RPC_BIND:-127.0.0.1}
rpcallowip=${RPC_ALLOWIP:-127.0.0.1}

# RPC Authentication (required)
rpcuser=${RPC_USER}
rpcpassword=${RPC_PASSWORD}

# Security Settings
rpcthreads=4
rpctimeout=30
rpcworkqueue=16

# Performance Settings
dbcache=450
maxorphantx=10
maxmempool=300
maxconnections=40

# Console output Settings
printtoconsole=1
logtimestamps=1

# Custom options
${CUSTOM_OPTS}