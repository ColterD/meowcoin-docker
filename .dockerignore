# Version control
.git
.gitignore
.github

# Node.js dependencies and logs
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log
**/node_modules
**/.npm
package-lock.json
yarn.lock

# Development files
**/.env.local
**/.env.development
**/.env.test
.editorconfig
.eslintrc
.prettierrc
tsconfig.tsbuildinfo

# Build artifacts that will be regenerated
**/dist
**/build
**/.cache
**/.parcel-cache

# Docker files
.dockerignore
docker-compose*.yml

# Documentation and markdown
**/*.md
**/docs

# Tests
**/test
**/tests
**/coverage
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Editor directories
.idea
.vscode
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db

# Meowcoin data (will be mounted as volume)
data/
config/

# Backup and temp files
**/*~
**/*.bak
**/tmp
**/temp

# Security sensitive files
**/*.pem
**/*.key
**/*.crt