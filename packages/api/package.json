{
  "name": "@meowcoin/api",
  "version": "2.0.0",
  "description": "API Gateway for MeowCoin Platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src test --ext .ts,.tsx,.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.3",
    "@fastify/rate-limit": "^9.0.1",
    "@fastify/swagger": "^8.12.0",
    "@fastify/websocket": "^8.2.0",
    "@meowcoin/blockchain": "^2.0.0",
    "@meowcoin/shared": "^2.0.0",
    "@prisma/client": "^5.6.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.3",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "pino": "^8.16.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.3",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "pino-pretty": "^10.2.3",
    "prisma": "^5.6.0",
    "rimraf": "^5.0.5",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
